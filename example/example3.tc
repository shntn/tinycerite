module adder {
    port {
        clk: input clock;
        a: input bit<8>;
        b: input bit<8>;
        sum: output bit<8>;
    }

    sum <= a + b;
}

testbench tb {
    var clk: clock;
    clk <= !clk;            // クロック分周

    var x: bit<8>;
    var y: bit<8>;
    var z: bit<8>;
    var u1 = adder(clk: clk, a: x, b: y);

    initial {
        x = 3;
        y = 4;
        step;               // 1サイクル進める
        step;
        z = u1.sum;
    }
}